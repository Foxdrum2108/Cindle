# Base de données SQLite (dev) ou PostgreSQL (prod)
DATABASE_URL="file:./dev.db"
# Pour PostgreSQL : DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/cindle"

# TMDB API - Read Access Token (JWT Bearer)
# Obtenez votre clé sur https://www.themoviedb.org/settings/api
TMDB_API_TOKEN="your_tmdb_read_access_token_here"

# Mot de passe pour accéder à la route admin /admin
ADMIN_PASSWORD="cindle-admin-secret"

# URL de base (utilisée pour le partage)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
